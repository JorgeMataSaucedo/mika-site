---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AuditRowWidget from '../components/AuditRowWidget.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SeriesIndex from '../components/SeriesIndex.astro';
---

<BaseLayout title="Mika">
  <Hero />
  <AuditRowWidget />
  <FeatureGrid />
  <SeriesIndex />

  <section class="max-w-3xl mx-auto px-6 py-20 text-center">
    <p class="wordmark text-3xl md:text-4xl text-accent leading-tight">
      Mika audita lo que Mika controla<br/>
      <span class="text-ink">— todo lo demás, lo declara.</span>
    </p>

    <p class="mt-12 text-lg md:text-xl font-semibold text-ink-soft leading-snug">
      "No estoy compitiendo con ChatGPT.
      Estoy compitiendo con el integrador que vende AI sin trazabilidad,
      sin portabilidad y sin auditabilidad —
      y cobra premium por el privilegio de quedarte atado."
    </p>
    <p class="mt-6 text-muted">— Mikata Renji · CDMX · 2026</p>
  </section>
</BaseLayout>
