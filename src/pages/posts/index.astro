---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Posts" description="Serie 'vibe-coding vs AI engineering' — cuatro posts, cuatro certs.">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-sm font-mono text-accent uppercase tracking-wider">Posts</p>
    <h1 class="mt-2 text-4xl md:text-5xl font-bold tracking-tight">
      Serie vibe-coding vs AI engineering
    </h1>
    <p class="mt-4 text-muted text-lg max-w-2xl">
      Cuatro posts mapeando una cert de Azure a una pieza concreta de mika-core.
      Largo. Honest. Sin marketing fluff.
    </p>

    <ul class="mt-12 divide-y divide-line border-t border-line">
      {posts.map((p) => (
        <li class="py-6">
          <a href={`/posts/${p.id.replace(/\.mdx?$/, '')}`} class="group block">
            <div class="flex items-center gap-2 flex-wrap">
              {p.data.cert && (
                <span class="font-mono text-xs text-accent-ink bg-accent-soft px-2 py-0.5 rounded">
                  {p.data.cert}
                </span>
              )}
              <span class="font-mono text-xs text-muted">
                {fmt(p.data.publishDate)}
                {p.data.readingMinutes && ` · ${p.data.readingMinutes} min lectura`}
              </span>
            </div>
            <h2 class="mt-2 text-2xl font-bold text-ink group-hover:text-accent transition-colors">
              {p.data.title}
            </h2>
            <p class="mt-2 text-ink-soft leading-relaxed">{p.data.summary}</p>
            <p class="mt-3 text-sm font-semibold text-accent group-hover:text-accent-ink">
              Lee el post →
            </p>
          </a>
        </li>
      ))}
      {posts.length === 0 && (
        <li class="py-8 text-muted">Pronto.</li>
      )}
    </ul>
  </section>
</BaseLayout>
