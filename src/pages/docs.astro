---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const docs = (await getCollection('docs')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<BaseLayout
  title="Docs"
  description="Mika explicada: documento largo, gratis, honest. Las tres certificaciones aplicadas en código real."
>
  <section class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-sm font-mono text-accent uppercase tracking-wider">Documentación</p>
    <h1 class="mt-2 text-4xl md:text-5xl font-bold tracking-tight">Mika explicada</h1>
    <p class="mt-4 text-muted text-lg max-w-2xl">
      Documento largo (~17K palabras) que explica qué es Mika, cómo funciona,
      y cómo cada certificación de Azure se materializó en código real. Honest,
      con auditoría visible y huecos declarados.
    </p>

    <div class="mt-10 border border-line rounded-md p-6 bg-paper-soft">
      <p class="font-semibold text-ink">Descargar PDF profesional</p>
      <p class="text-sm text-muted mt-1">
        Versión compilada (cover + TOC + 3 partes) · 1.7&nbsp;MB · ~60&nbsp;pp
      </p>
      <a
        href="/downloads/Mika-explicada-completo.pdf"
        class="mt-4 inline-flex items-center gap-2 px-5 py-3 bg-accent text-white rounded-md font-semibold hover:bg-accent-ink transition-colors"
      >
        Descargar el PDF
        <span aria-hidden="true">↓</span>
      </a>
    </div>

    <ul class="mt-12 divide-y divide-line border-t border-line">
      {docs.map((d) => (
        <li class="py-6">
          <a href={`/docs/${d.id.replace(/\.mdx?$/, '')}`} class="group block">
            <h2 class="text-2xl font-bold text-ink group-hover:text-accent transition-colors">
              {d.data.title}
            </h2>
            <p class="mt-2 text-ink-soft">{d.data.summary}</p>
            <p class="mt-3 text-sm font-semibold text-accent group-hover:text-accent-ink">
              Lee el capítulo →
            </p>
          </a>
        </li>
      ))}
      {docs.length === 0 && (
        <li class="py-8 text-muted">Capítulos web próximamente — por ahora descarga el PDF.</li>
      )}
    </ul>
  </section>
</BaseLayout>
