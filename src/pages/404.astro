---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Página no encontrada" noindex>
  <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <p class="font-mono text-accent text-sm uppercase tracking-wider">404</p>
    <h1 class="mt-3 text-5xl md:text-6xl font-bold tracking-tight">No está aquí.</h1>
    <p class="mt-6 text-lg text-ink-soft max-w-xl mx-auto">
      Esta URL no existe (todavía) o se mudó. Si llegaste de un link de hace
      meses, las cosas se reorganizan — pero el contenido sigue vivo.
    </p>
    <div class="mt-10 flex justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-5 py-3 bg-accent text-white rounded-md font-semibold hover:bg-accent-ink transition-colors"
      >
        ← Volver al inicio
      </a>
      <a
        href="/posts"
        class="inline-flex items-center gap-2 px-5 py-3 border border-line rounded-md font-semibold text-ink-soft hover:border-accent hover:text-accent transition-colors"
      >
        Ver la serie de posts
      </a>
    </div>
  </section>
</BaseLayout>
