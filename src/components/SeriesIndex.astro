---
const series = [
  {
    n: 1,
    cert: 'AI-102',
    title: 'Cada Operation es infraestructura, no un wrapper',
    date: '18 jun 2026',
    href: '/posts/ai-102',
    status: 'upcoming',
  },
  {
    n: 2,
    cert: 'AZ-204',
    title: 'Tu bill de Azure AI dice todo de tu arquitectura',
    date: '25 jun 2026',
    href: null,
    status: 'planned',
  },
  {
    n: 3,
    cert: 'AZ-500',
    title: 'Anti-hallucination by test no es feature, es responsabilidad',
    date: '2 jul 2026',
    href: null,
    status: 'planned',
  },
  {
    n: 4,
    cert: null,
    title: 'Las certs son spec de arquitectura, no CV padding',
    date: '9 jul 2026',
    href: null,
    status: 'planned',
  },
];

const statusLabel = {
  upcoming: 'Próximo · 18 jun',
  planned: 'Planeado',
  published: 'Publicado',
};
const statusClass = {
  upcoming: 'bg-accent-soft text-accent-ink',
  planned: 'bg-line-soft text-muted',
  published: 'bg-green-50 text-green-700',
};
---

<section class="border-b border-line bg-paper-soft">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <p class="text-sm font-mono text-accent uppercase tracking-wider">
      Serie · vibe-coding vs AI engineering
    </p>
    <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight text-ink">
      Cuatro posts, cuatro certs, cuatro semanas
    </h2>

    <ol class="mt-10 divide-y divide-line border border-line rounded-md bg-paper overflow-hidden">
      {series.map((s) => (
        <li class="px-6 py-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <div class="flex items-start gap-4">
            <span class="font-mono text-sm text-muted mt-1">#{s.n}</span>
            <div>
              <div class="flex items-center gap-2 flex-wrap">
                {s.cert && (
                  <span class="font-mono text-xs text-accent-ink bg-accent-soft px-2 py-0.5 rounded">
                    {s.cert}
                  </span>
                )}
                <span class={`text-xs px-2 py-0.5 rounded ${statusClass[s.status as keyof typeof statusClass]}`}>
                  {statusLabel[s.status as keyof typeof statusLabel]}
                </span>
              </div>
              <p class="mt-1 font-semibold text-ink">{s.title}</p>
              <p class="text-sm text-muted">{s.date}</p>
            </div>
          </div>
          <div>
            {s.href ? (
              <a
                href={s.href}
                class="text-sm font-semibold text-accent hover:text-accent-ink underline underline-offset-2"
              >
                Lee →
              </a>
            ) : (
              <span class="text-sm text-muted">Pronto</span>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
